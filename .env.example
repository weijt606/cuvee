# =============================================================================
# Cuvée — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real keys. This repo is public.
#
# Every provider is env-gated. Leave a key blank and that provider is simply
# unavailable. Cuvée works as long as at least one LLM provider is configured.
# =============================================================================

# ---- Public-safe ----
NEXT_PUBLIC_APP_NAME="Cuvée"
# When DEMO_MODE=true, the orchestrator returns fixtures from
# src/lib/demo/fixtures.ts. Use for offline rehearsal / saving credits.
NEXT_PUBLIC_DEMO_MODE=false
# DEMO_FAST controls whether /api/analyze uses the direct-dispatch
# pipeline (true, default) or the GPT tool-use orchestration loop (false).
# Default is true — the fast path is ~30 s vs ~80 s for our fixed agent flow.
NEXT_PUBLIC_DEMO_FAST=true

# =============================================================================
# LLM PROVIDERS
# =============================================================================
# CUVEE_LLM_PROVIDER picks which provider handles every agent LLM call
# (extraction, feature, backtest, orchestrator routing).
# Options: openai (default), anthropic, qwen, deepseek, ollama
CUVEE_LLM_PROVIDER=openai
# Optional: override the chosen provider's model id. When unset, each provider
# falls back to its own *_MODEL env var (below) or a baked-in default.
CUVEE_LLM_MODEL=

# ---- OpenAI (default) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# RECOMMENDED: gpt-4o-mini — structured-JSON tasks against a fixed schema.
# AVOID reasoning models (gpt-5*, o-series): they add 20-40 s of internal
# "thinking" that doesn't help here.
OPENAI_MODEL=gpt-4o-mini

# ---- Anthropic Claude (alt) ----
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Alibaba Qwen via DashScope (alt, OpenAI-compatible mode) ----
# https://dashscope-intl.aliyuncs.com/
QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ---- DeepSeek (alt, OpenAI-compatible) ----
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---- Ollama (local, free, OpenAI-compatible) ----
# Run `ollama serve` locally, then `ollama pull qwen2.5:7b`. No API key needed.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# =============================================================================
# RETRIEVAL PROVIDERS (public-web grounding for the harness + backtest)
# =============================================================================
# CUVEE_RETRIEVAL_PROVIDER picks the search backend. When unset, the system
# prefers the first configured provider in this order:
#   tavily → searxng → brave → null
# Options: tavily, brave, searxng, null
# CUVEE_RETRIEVAL_PROVIDER=tavily

# ---- Tavily (managed API, paid plans; free tier ~1k/mo) ----
# https://app.tavily.com/home
TAVILY_API_KEY=

# ---- Brave Search (managed API, free tier 2k/mo, no card needed) ----
# https://api.search.brave.com/
BRAVE_API_KEY=

# ---- SearXNG (self-hosted, truly free — no API key, no quota) ----
# Quick start (Docker):
#   docker run -d --name searxng -p 8888:8080 \
#     -e BASE_URL=http://localhost:8888/ searxng/searxng:latest
# Then set SEARXNG_BASE_URL to your instance's URL.
SEARXNG_BASE_URL=
# Optional bearer token if your SearXNG instance is behind auth:
SEARXNG_API_KEY=

# =============================================================================
# Server runtime
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
